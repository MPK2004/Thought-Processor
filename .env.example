# Qdrant (external)
QDRANT_URL=https://your-qdrant-instance.cloud.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_COLLECTION=dealer_docs

# Groq LLM
GROQ_API_KEY=your-groq-api-key

# Redis (matches docker-compose service name)
REDIS_URL=redis://redis:6379

# PostgreSQL (matches docker-compose service name)
DATABASE_URL=postgresql://rag:rag@postgres:5432/rag

# Upload directory (shared volume mount point)
UPLOAD_DIR=/app/uploads

# Worker retry config
MAX_RETRIES=3

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=dealer-rag
